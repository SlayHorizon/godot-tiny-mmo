[gd_resource type="Resource" script_class="JobPerks" format=3]

[ext_resource type="Script" path="res://source/common/gameplay/jobs/job_perks.gd" id="1_jp"]
[ext_resource type="Script" path="res://source/common/gameplay/items/item.gd" id="1_u1igm"]
[ext_resource type="Resource" path="res://source/common/gameplay/items/gears/cloth/cloth_hood.tres" id="2_hood"]
[ext_resource type="Resource" path="res://source/common/gameplay/items/gears/leather/leather_jacket.tres" id="3_jacket"]

[resource]
script = ExtResource("1_jp")
job_slug = &"outfitting"
display_name = "Outfitting"
category = &"crafting"
sort_order = 1
perks = Array[Dictionary]([{
"effect": "xp",
"id": "apprentice",
"max_rank": 3,
"name": "Apprentice",
"per_rank": 0.1
}, {
"effect": "refund",
"id": "frugal",
"max_rank": 3,
"name": "Frugal",
"per_rank": 0.05
}, {
"effect": "extra_item",
"id": "steady_hand",
"max_rank": 3,
"name": "Steady Hand",
"per_rank": 0.04
}])
recipe_items = Array[ExtResource("1_u1igm")]([ExtResource("2_hood"), ExtResource("3_jacket")])
recipe_levels = Array[int]([0, 0])
describe_lines = Array[String](["Outfitting XP +{xp}%", "Material refund: {refund}%", "Extra item: {extra_item}%"])
