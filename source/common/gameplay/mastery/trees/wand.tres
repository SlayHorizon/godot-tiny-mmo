[sub_resource type="Resource" id="Mod_ap_attunement"]
script = ExtResource("3_mod")
stat_name = "ap"
value = 5.0

[sub_resource type="Resource" id="Node_attunement"]
script = ExtResource("2_node")
id = &"wand_attunement"
node_name = "Attunement"
description = "+5 ability power."
branch = &"domination"
tier = 1
icon = ExtResource("8_sp")
passive_modifiers = Array[ExtResource("3_mod")]([SubResource("Mod_ap_attunement")])

[sub_resource type="Resource" id="Mod_mr_warding"]
script = ExtResource("3_mod")
stat_name = "mr"
value = 6.0

[sub_resource type="Resource" id="Node_warding"]
script = ExtResource("2_node")
id = &"wand_warding"
node_name = "Warding"
description = "+6 magic resistance."
branch = &"resolve"
tier = 1
icon = ExtResource("9_ward")
passive_modifiers = Array[ExtResource("3_mod")]([SubResource("Mod_mr_warding")])

[sub_resource type="Resource" id="Node_wall"]
script = ExtResource("2_node")
id = &"wand_wall"
node_name = "Arcane Wall"
description = "Conjures a short-lived wall ahead of you that soaks projectiles from any side (yours included) until it shatters. Weight 2."
branch = &"resolve"
tier = 2
ability = ExtResource("6_wall")

[sub_resource type="Resource" id="Node_heal"]
script = ExtResource("2_node")
id = &"wand_heal"
node_name = "Heal Bolt"
description = "A bolt that mends instead of harms. Mount it in your wand's special slot to heal allies."
branch = &"inspiration"
tier = 1
ability = ExtResource("4_heal")

[sub_resource type="Resource" id="Node_fireball"]
script = ExtResource("2_node")
id = &"wand_fireball"
description = "Hurl a blazing comet that explodes where it lands, scorching everything around the blast and leaving them burning. Weight 2."
branch = &"domination"
tier = 2
ability = ExtResource("10_fireball")

[sub_resource type="Resource" id="Node_frost"]
script = ExtResource("2_node")
id = &"wand_frost_nova"
description = "Blast a freezing ring around you, damaging and slowing everyone caught in it. Your escape button when they get close. Weight 2."
branch = &"resolve"
tier = 2
ability = ExtResource("11_frost")

[sub_resource type="Resource" id="Node_siphon"]
script = ExtResource("2_node")
id = &"wand_life_siphon"
description = "Channel a crimson beam that drains whoever you aim at, converting their life into your mana. The arcanist's refuel. Weight 2."
branch = &"inspiration"
tier = 2
ability = ExtResource("12_siphon")

[sub_resource type="Resource" id="Node_meteor"]
script = ExtResource("2_node")
id = &"wand_meteor"
description = "Call a meteor down on the spot you aim. The sky marks the strike, the comet falls, and everything in the blast burns. The arcanist's ultimate: heaviest technique, weight 4."
branch = &"domination"
tier = 4
ability = ExtResource("14_meteor")

[sub_resource type="Resource" id="Node_font"]
script = ExtResource("2_node")
id = &"wand_mana_font"
description = "Plant your wand and open a font of mana. You and nearby allies steadily recover mana while you hold the channel. The group's refuel circle after a hard fight. Weight 2."
branch = &"inspiration"
tier = 3
ability = ExtResource("15_font")

[sub_resource type="Resource" id="Mod_regen_clarity"]
script = ExtResource("3_mod")
stat_name = "mana_regen"
value = 0.5

[sub_resource type="Resource" id="Node_clarity"]
script = ExtResource("2_node")
id = &"wand_clarity"
node_name = "Clarity"
description = "+0.5 mana regen per second."
branch = &"inspiration"
tier = 1
icon = ExtResource("13_clarity")
passive_modifiers = Array[ExtResource("3_mod")]([SubResource("Mod_regen_clarity")])

[resource]
script = ExtResource("1_tree")
category = &"wand"
display_name = "Wand"
nodes = Array[ExtResource("2_node")]([SubResource("Node_attunement"), SubResource("Node_fireball"), SubResource("Node_meteor"), SubResource("Node_warding"), SubResource("Node_wall"), SubResource("Node_frost"), SubResource("Node_clarity"), SubResource("Node_heal"), SubResource("Node_siphon"), SubResource("Node_font")])
