[sub_resource type="Resource" id="Node_ww1"]
script = ExtResource("2_node")
id = &"sword_whirlwind"
description = "Spin in a blur of steel, hitting everything around you. You move slowly while it spins."
branch = &"domination"
ability = ExtResource("4_ww1")

[sub_resource type="Resource" id="Node_ww2"]
script = ExtResource("2_node")
id = &"sword_whirlwind_2"
description = "A longer, wider spin that grinds down everyone near you."
branch = &"domination"
tier = 2
ability = ExtResource("5_ww2")
upgrades = &"sword_whirlwind"

[sub_resource type="Resource" id="Node_ww3"]
script = ExtResource("2_node")
id = &"sword_whirlwind_3"
description = "An unrelenting steel cyclone: the widest, longest spin you can hold."
branch = &"domination"
tier = 3
ability = ExtResource("6_ww3")
upgrades = &"sword_whirlwind_2"

[sub_resource type="Resource" id="Node_bsk1"]
script = ExtResource("2_node")
id = &"sword_berserk"
description = "Go berserk. For a few seconds you heal part of every hit you land, so you can fight your way back from low health."
branch = &"domination"
tier = 2
ability = ExtResource("9_bsk1")

[sub_resource type="Resource" id="Node_bsk2"]
script = ExtResource("2_node")
id = &"sword_berserk_2"
description = "Heals more, lasts longer, and sharpens your blade while it rages."
branch = &"domination"
tier = 3
ability = ExtResource("10_bsk2")
upgrades = &"sword_berserk"

[sub_resource type="Resource" id="Node_bsk3"]
script = ExtResource("2_node")
id = &"sword_berserk_3"
description = "Full bloodlust: the strongest, longest rage you can call."
branch = &"domination"
tier = 4
ability = ExtResource("11_bsk3")
upgrades = &"sword_berserk_2"

[sub_resource type="Resource" id="Mod_armor_parry"]
