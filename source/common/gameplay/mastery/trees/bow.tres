[sub_resource type="Resource" id="Node_multishot"]
script = ExtResource("2_node")
id = &"bow_multishot"
node_name = "Multishot"
description = "Arm your bow: the next arrow you draw splits into a fan of three. The deeper the draw, the harder the fan hits."
branch = &"domination"
ability = ExtResource("4_multi")

[sub_resource type="Resource" id="Node_storm"]
script = ExtResource("2_node")
id = &"bow_arrowstorm"
node_name = "Arrow Storm"
description = "Arm your bow: the next draw unleashes a wide storm of seven arrows. Weight 3."
branch = &"domination"
tier = 3
ability = ExtResource("6_storm")
upgrades = &"bow_multishot"

[sub_resource type="Resource" id="Node_deadeye"]
script = ExtResource("2_node")
id = &"bow_deadeye"
description = "Arm your bow: the next arrow becomes a sniper round that punches through targets, flying faster and hitting harder. Weight 1."
branch = &"domination"
tier = 2
ability = ExtResource("10_deadeye")

[sub_resource type="Resource" id="Node_deadeye2"]
script = ExtResource("2_node")
id = &"bow_deadeye_2"
description = "The perfected sniper round: pierces everything in its path, faster and deadlier still. Weight 2."
branch = &"domination"
tier = 3
ability = ExtResource("11_deadeye2")
upgrades = &"bow_deadeye"

[sub_resource type="Resource" id="Mod_hp_survival"]
script = ExtResource("3_mod")
value = 12.0

[sub_resource type="Resource" id="Node_survival"]
script = ExtResource("2_node")
id = &"bow_survival"
