description = "+12 max health."
branch = &"resolve"
icon = ExtResource("7_jug")
passive_modifiers = Array[ExtResource("3_mod")]([SubResource("Mod_hp_survival")])

[sub_resource type="Resource" id="Node_rain"]
script = ExtResource("2_node")
id = &"bow_rain_of_arrows"
description = "Call a volley down on the spot you aim. Arrows crash into everyone there, then stick in the ground, slowing whoever dares cross. Weight 2."
branch = &"resolve"
tier = 3
ability = ExtResource("13_rain")

[sub_resource type="Resource" id="Node_pin"]
script = ExtResource("2_node")
id = &"bow_pinning_arrow"
description = "Arm a massive arrow. Your next full draw releases it: the first one it strikes is PINNED to the ground, stunned, while the shockwave slows everyone around. The marksman's ultimate: heaviest technique, weight 4."
branch = &"resolve"
tier = 4
ability = ExtResource("14_pin")

