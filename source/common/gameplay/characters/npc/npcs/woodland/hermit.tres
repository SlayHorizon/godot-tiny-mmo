[sub_resource type="Resource" id="Dialogue_quiet"]
script = ExtResource("4_dialogue")
lines = Array[String](["The camp asks where things come from. I only ask what they weigh.", "Past the wall it is quiet here. The good kind of quiet. Mostly.", "Sell me what you do not need. The forest keeps its own accounts."])
label_override = "Ask why he lives here"

[resource]
script = ExtResource("1_npcres")
npc_name = "the Hermit"
skin = ExtResource("6_skin")
greeting = "Not many find this place. Fewer leave with lighter packs. Show me what you carry."
interactions = Array[ExtResource("2_npcint")]([SubResource("ShopInteraction_hermit"), SubResource("Dialogue_quiet")])
