[gd_resource type="Resource" script_class="NPCResource" format=3]

[ext_resource type="Script" path="res://source/common/gameplay/characters/npc/interactions/npc_interaction.gd" id="1_inter"]
[ext_resource type="Script" path="res://source/common/gameplay/characters/npc/interactions/shop_interaction.gd" id="2_shopint"]
[ext_resource type="Resource" path="res://source/common/gameplay/shops/resources/fire_shop.tres" id="3_shop"]
[ext_resource type="Script" path="res://source/common/gameplay/characters/npc/interactions/dialogue_interaction.gd" id="4_diag"]
[ext_resource type="Script" path="res://source/common/gameplay/characters/npc/npc_resource.gd" id="5_npc"]
[ext_resource type="SpriteFrames" path="res://source/common/gameplay/characters/sprite_frames/knight.tres" id="6_skin"]

[sub_resource type="Resource" id="Shop"]
script = ExtResource("2_shopint")
shop = ExtResource("3_shop")

[sub_resource type="Resource" id="Talk"]
script = ExtResource("4_diag")
lines = Array[String](["Every piece here cost someone a steadier life. Pay in coin, it is the cheaper price.", "I do not make these. I collect what the fire leaves behind and ask a fair markup.", "There is nothing past this counter but the fire itself. Buy well. You will not shop again."])
label_override = "Ask about the wares"

[resource]
script = ExtResource("5_npc")
npc_name = "Ashmonger"
skin = ExtResource("6_skin")
greeting = "You walked through everything between here and the green country to reach my counter. So look. Everything here was pulled out of the fire by people who did not all walk back."
interactions = Array[ExtResource("1_inter")]([SubResource("Shop"), SubResource("Talk")])
