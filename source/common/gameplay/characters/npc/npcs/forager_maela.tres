[sub_resource type="Resource" id="Dialogue_glow"]
script = ExtResource("4_dialogue")
lines = Array[String](["The glow is pretty until you learn what it eats.", "This cave used to be a clean dig. Then the seep reached it and the fungus learned to walk.", "Keep to the lit galleries. What waits in the deep passage is worse than mushrooms."])
label_override = "Ask about the glow"

[resource]
script = ExtResource("1_npcres")
npc_name = "Forager Maela"
skin = ExtResource("11_skin")
greeting = "Watch your step, the caps burst when you crowd them. You here to clear the galleries? Good. I mark what needs cutting, you cut it."
interactions = Array[ExtResource("2_npcint")]([SubResource("QuestInteraction_maela"), SubResource("Dialogue_glow")])
