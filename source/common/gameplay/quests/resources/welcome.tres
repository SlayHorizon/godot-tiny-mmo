[resource]
script = ExtResource("2_quest")
quest_name = "Find Your Footing"
description = "New to these parts? Then take a walk. Mira keeps the apothecary on the east side, the Master Smith works the forge to the south. Introduce yourself — they'll point you at honest work."
objectives = Array[ExtResource("1_obj")]([SubResource("Obj_visit_mira"), SubResource("Obj_visit_smith")])
completion = 1
reward_xp = 25
reward_gold = 5
reward_items = Array[ExtResource("3_reward")]([SubResource("Reward_potion")])
grant_title = "Newcomer"
